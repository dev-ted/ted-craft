{
  "name": "@ted-craft/monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node scripts/ws.mjs @ted-craft/validate generate && node scripts/ws.mjs @ted-craft/web dev",
    "build": "node scripts/ws.mjs @ted-craft/validate generate && node scripts/ws.mjs @ted-craft/web build",
    "generate": "node scripts/ws.mjs @ted-craft/validate generate",
    "validate": "node scripts/ws.mjs @ted-craft/validate validate",
    "types:check": "node scripts/ws.mjs @ted-craft/validate generate && node scripts/ws.mjs @ted-craft/web types:check",
    "cli": "node scripts/ws.mjs ted-craft start",
    "ted-craft": "node packages/cli/dist/cli.js",
    "cli:build": "node scripts/ws.mjs ted-craft build",
    "cli:pack": "node scripts/ws.mjs ted-craft pack",
    "cli:publish:dry": "node scripts/ws.mjs ted-craft publish:dry",
    "cli:publish": "node scripts/ws.mjs ted-craft publish:npm",
    "cli:version:patch": "node scripts/cli-version.mjs patch",
    "cli:version:minor": "node scripts/cli-version.mjs minor",
    "cli:version:major": "node scripts/cli-version.mjs major",
    "cli:tag": "node scripts/cli-tag.mjs",
    "lint": "node scripts/ws.mjs @ted-craft/web lint"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
